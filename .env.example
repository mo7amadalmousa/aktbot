# AktBot — متغيّرات البيئة (انسخ إلى .env واملأ القيم الحقيقية)

# Neon Postgres — سلسلة الاتصال المجمّعة (pooled). لا تضع أسراراً حقيقية هنا.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# عنوان التطبيق العام (بلا شرطة مائلة في النهاية).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
