# AktBot — متغيّرات البيئة (انسخ إلى .env واملأ القيم الحقيقية)

# Neon Postgres — سلسلة الاتصال المجمّعة (pooled). لا تضع أسراراً حقيقية هنا.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# عنوان تطبيق app العام (بلا شرطة مائلة في النهاية). محلياً: http://localhost:3009
NEXT_PUBLIC_APP_URL="http://localhost:3009"

# سرّ توقيع JWT للجلسات — أنشئ سرّاً عشوائياً طويلاً:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="generate-a-long-random-secret"

# مزوّد الدفع (mock الآن · iyzico/stripe لاحقاً).
PAYMENT_PROVIDER="mock"

# توجيه النطاقات (proxy.ts). محلياً تُترك فارغة → المضيف = منطقة app.
# الإنتاج:
# APP_HOST="app.aktbot.com"
# LINK_HOST="aktbot.link"
# MARKETING_HOST="aktbot.com"
