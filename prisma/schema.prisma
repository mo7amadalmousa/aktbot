// AktBot — Prisma schema (Neon Postgres, pooled)
// القاعدة: additive فقط — لا حذف أعمدة/جداول/بيانات قائمة.
// Prisma 7: لا يوضع url هنا — سلسلة الاتصال في prisma.config.ts، والاتصال عبر adapter.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── فحص السلامة (Bootstrap) — يبقى كما هو ───────────────────────────
model HealthCheck {
  id        String   @id @default(cuid())
  label     String
  createdAt DateTime @default(now())
}

// ── الأدوار وأنواع البلوكات ──────────────────────────────────────────
enum Role {
  CREATOR
  BRAND
  ADMIN
}

// نظام بلوكات كامل البنية — الأنواع تُفعّل بموجات لاحقة (الآن الـenum فقط).
enum BlockType {
  LINK
  FORM
  GALLERY
  EMBED
  CONSULTATION
  PAID_VIDEO
  STORE
  NEWSLETTER
  QR
  BEFORE_AFTER
  STORY
  SOCIAL
  DISCOUNT
}

// ── المستخدم والمصادقة ───────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(CREATOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatorProfile          CreatorProfile?
  brandProfile            BrandProfile?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mediaAssets             MediaAsset[]
}

// أصل صورة مرفوع — يتتبّع الملكيّة (للحذف الآمن) والمفتاح على التخزين.
model MediaAsset {
  id        String   @id @default(cuid())
  key       String   @unique // اسم الملف العشوائيّ على التخزين (cuid.webp)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// التوكنات مُخزّنة مجزّأة (sha256) لا نصاً صريحاً · صلاحية قصيرة · استخدام مرّة واحدة.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── ملف المبدع + الصفحة + البلوكات ───────────────────────────────────
model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  username    String   @unique // مسار aktbot.link/username لاحقاً — slug مُتحقَّق
  displayName String
  bio         String?
  avatarUrl   String?
  language    String   @default("ar")
  direction   String   @default("rtl")
  isPublished Boolean  @default(false)
  // حقول العرض العامّ (additive) — رأس الصفحة العامّة.
  isVerified    Boolean @default(false)
  followerCount Int     @default(0)
  socialLinks   Json? // { instagram, tiktok, youtube, x, website, ... } — تُنقّى عند الإدخال لاحقاً
  createdAt   DateTime @default(now())

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  page        Page?
  orders       Order[]
  subscribers  NewsletterSubscriber[]
  products     Product[]
  availability Availability?
  bookings     Booking[]
  pageViews    PageViewDaily[]
  blockClicks  BlockClick[]
  commissions  CommissionLedger[]
  participations CampaignParticipation[]
  campaignPayouts CampaignPayout[]
  contentSubmissions ContentSubmission[]
}

// مشتركو النشرة البريديّة لكل مبدع (جمع فقط الآن؛ إرسال الحملات لاحقاً).
model NewsletterSubscriber {
  id               String   @id @default(cuid())
  creatorProfileId String
  email            String
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, email])
  @@index([creatorProfileId])
}

model Page {
  id               String   @id @default(cuid())
  creatorProfileId String   @unique
  theme            Json?
  background       Json?
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  blocks         Block[]
}

model Block {
  id         String    @id @default(cuid())
  pageId     String
  type       BlockType
  config     Json?
  order      Int       @default(0)
  visibility Boolean   @default(true)
  createdAt  DateTime  @default(now())

  page           Page            @relation(fields: [pageId], references: [id], onDelete: Cascade)
  storyViews     StoryView[]
  couponCounters CouponCounter[]

  @@index([pageId])
}

// عدّاد نسخ كوبونات الخصم — مجمّع (أخفّ من صفّ لكل نسخة) · بيانات أفلييت للمبدع.
model CouponCounter {
  id        String   @id @default(cuid())
  blockId   String
  couponId  String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, couponId])
  @@index([blockId])
}

// تتبّع مشاهدة ستوري VIEW_ONCE لكل زائر مجهول (visitorId = كوكي opaque، بلا هوية).
model StoryView {
  id        String   @id @default(cuid())
  blockId   String
  visitorId String
  createdAt DateTime @default(now())

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, visitorId])
  @@index([blockId])
}

// ── الطلبات/المدفوعات (طبقة دفع محايدة) ──────────────────────────────
enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Order {
  id               String      @id @default(cuid())
  creatorProfileId String
  buyerName        String
  buyerEmail       String
  blockType        BlockType? // طلب بلوك: CONSULTATION | PAID_VIDEO
  blockId          String?
  productId        String? // طلب منتج متجر (بديل عن البلوك)
  participationId  String? // إسناد لحملة (عبر رابط/كود المبدع) — لتوزيع العمولة
  amount           Int // أصغر وحدة (minor units) — لتفادي أخطاء العشرية
  currency         String
  status           OrderStatus @default(PENDING)
  provider         String      @default("mock")
  providerRef      String?     @unique // مرجع المزوّد — يضمن idempotency للـwebhook
  metadata         Json?
  // حقول الشحن (المنتج الفيزيائيّ) — additive، تبقى null لغير الفيزيائيّ.
  fulfillmentStatus FulfillmentStatus?
  trackingNumber    String?
  shippingFee       Int? // رسوم الشحن بأصغر وحدة (من القاعدة)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creatorProfile  CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  downloadTokens  DownloadToken[]
  enrollment      CourseEnrollment?
  shippingAddress ShippingAddress?
  booking         Booking?
  commission      CommissionLedger?
  participation   CampaignParticipation? @relation(fields: [participationId], references: [id], onDelete: SetNull)

  @@index([creatorProfileId])
  @@index([status])
  @@index([participationId])
}

// ── المتجر الفعليّ (شراء داخليّ) ──────────────────────────────────────
enum ProductType {
  DIGITAL
  COURSE
  PHYSICAL
}

model Product {
  id               String      @id @default(cuid())
  creatorProfileId String
  type             ProductType @default(DIGITAL)
  title            String
  description      String?
  price            Int // minor units
  currency         String
  images           Json? // روابط صور (عبر طبقة الرفع)
  isActive         Boolean     @default(true)
  // الفيزيائيّ (additive): مخزون اختياريّ (null = غير محدود) + رسوم شحن اختياريّة.
  stock            Int?
  shippingFee      Int? // minor units
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creatorProfile CreatorProfile     @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  assets         ProductAsset[]
  orders         Order[]
  modules        CourseModule[] // بنية الكورس (type=COURSE)
  enrollments    CourseEnrollment[]

  @@index([creatorProfileId])
}

// ملف المنتج الرقميّ — تخزين خاصّ (fileKey في UPLOAD_DIR/private، لا يُخدَم عاماً).
model ProductAsset {
  id        String   @id @default(cuid())
  productId String
  fileKey   String // مفتاح الملف الخاصّ
  fileName  String
  size      Int
  createdAt DateTime @default(now())

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadTokens DownloadToken[]

  @@index([productId])
}

// رابط تحميل آمن محدود بعد دفع مؤكّد (توكن مجزّأ · صلاحية · حدّ تحميل).
model DownloadToken {
  id             String   @id @default(cuid())
  orderId        String
  productAssetId String
  tokenHash      String   @unique
  expiresAt      DateTime
  maxDownloads   Int      @default(5)
  downloadCount  Int      @default(0)
  createdAt      DateTime @default(now())

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productAsset ProductAsset @relation(fields: [productAssetId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ── الكورس (type=COURSE): وحدات ← دروس، ووصول المشتري عبر Enrollment ──
enum LessonType {
  VIDEO // فيديو مرفوع (خاصّ) أو تضمين
  TEXT // نصّ الدرس
  FILE // ملف مرفق (خاصّ)
}

model CourseModule {
  id        String   @id @default(cuid())
  productId String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([productId])
}

model CourseLesson {
  id         String     @id @default(cuid())
  moduleId   String
  title      String
  order      Int        @default(0)
  type       LessonType @default(TEXT)
  contentRef String? // نصّ الدرس (TEXT) أو رابط تضمين (VIDEO embed)
  assetKey   String? // ملف/فيديو مرفوع في التخزين الخاصّ (VIDEO upload | FILE)
  assetName  String?
  duration   String?
  createdAt  DateTime   @default(now())

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

// وصول المشتري لمحتوى الكورس بعد الدفع — رابط غير قابل للتخمين (مجزّأ).
model CourseEnrollment {
  id               String   @id @default(cuid())
  orderId          String   @unique
  productId        String
  buyerEmail       String
  tokenHash        String   @unique
  completedLessons Json? // تقدّم أساسيّ: معرّفات الدروس المكتملة
  createdAt        DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ── الشحن (type=PHYSICAL) ─────────────────────────────────────────────
enum FulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model ShippingAddress {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fullName   String
  phone      String
  country    String
  city       String
  line       String
  postalCode String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ── حجز المواعيد (ترقية CONSULTATION) ─────────────────────────────────
// توفّر المبدع: نمط أسبوعيّ مرن (JSON) + منطقة زمنية + مدّة/فاصل/أفق.
// اخترتُ توفّراً واحداً لكل مبدع (creatorProfileId @unique) مع weekly JSON
// (أبسط وأمرن من صفوف؛ الاستثناءات JSON اختياريّة).
model Availability {
  id               String   @id @default(cuid())
  creatorProfileId String   @unique
  timezone         String   @default("UTC") // IANA (مثل Europe/Istanbul)
  slotMinutes      Int      @default(30) // مدّة الجلسة
  bufferMinutes    Int      @default(0) // فاصل بين المواعيد
  horizonDays      Int      @default(30) // أفق الحجز مقدّماً
  weekly           Json? // [{ day:0-6, ranges:[{ start:"09:00", end:"17:00" }] }]
  exceptions       Json? // ["2026-07-20", ...] أيام إجازة (تعطيل)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  PENDING // مدفوع بانتظار الدفع (hold)
  CONFIRMED
  CANCELLED
  COMPLETED
}

// حجز موعد. منع الازدواج الذرّيّ عبر slotKey فريد (يُضبط للمواعيد النشطة فقط،
// ويُفرَّغ null عند الإلغاء/انتهاء الـhold فيتحرّر الموعد). المواعيد مولّدة بمحاذاة
// slotMinutes فالتصادم = نفس startAt بالضبط.
model Booking {
  id                  String        @id @default(cuid())
  creatorProfileId    String
  consultationBlockId String
  buyerName           String
  buyerEmail          String
  startAt             DateTime
  endAt               DateTime
  status              BookingStatus @default(PENDING)
  isPaid              Boolean       @default(false)
  orderId             String?       @unique
  meetingLink         String?
  meetingType         String        @default("online") // online | in_person
  holdExpiresAt       DateTime? // للمدفوع PENDING — يُحرَّر بعدها
  slotKey             String?       @unique // "<creatorProfileId>|<startISO>" للنشط، null للمحرَّر
  createdAt           DateTime      @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([creatorProfileId])
  @@index([consultationBlockId])
  @@index([status])
}

// ── التحليلات (تتبّع مجمّع خفيف — مبنيّ للمقياس) ───────────────────────
// قرار: عدّاد يوميّ مجمّع (صفّ لكل مبدع/يوم) لا صفّ لكل زيارة — يتحمّل ملايين
// الزيارات. الفريد اليوميّ يُدَّوب عبر VisitorDay (صفّ لكل زائر فريد/يوم، أصغر
// بكثير من عدد الزيارات). لا PII — معرّف الزائر مجهول (aktbot_vid).
model PageViewDaily {
  id               String   @id @default(cuid())
  creatorProfileId String
  date             String // YYYY-MM-DD (UTC)
  views            Int      @default(0)
  uniques          Int      @default(0)
  srcDirect        Int      @default(0)
  srcSocial        Int      @default(0)
  srcOther         Int      @default(0)
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, date])
  @@index([creatorProfileId])
  @@index([date])
}

// دِدوب الزائر الفريد يوميّاً (لا يُخزَّن أيّ حدث زيارة فرديّ). idempotent عبر القيد.
model VisitorDay {
  id               String   @id @default(cuid())
  creatorProfileId String
  visitorId        String
  date             String
  createdAt        DateTime @default(now())

  @@unique([creatorProfileId, visitorId, date])
  @@index([creatorProfileId, date])
}

// نقرات البلوك — مجمّع (صفّ لكل بلوك). نفس فلسفة CouponCounter.
model BlockClick {
  id               String   @id @default(cuid())
  blockId          String   @unique
  creatorProfileId String
  count            Int      @default(0)
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId])
}

// ── طبقة العمولة: محرّك هرميّ + سجلّ Ledger ───────────────────────────
// المنصّة مجّانيّة، دخلها عمولة على كل بيعة مؤكّدة. القاعدة الأخصّ تفوز.
enum CommissionScope {
  GLOBAL // افتراضيّ شامل (fallback)
  BY_TYPE // حسب نوع البيع
  BY_BRAND // حسب العلامة (طبقة لاحقة)
  BY_CREATOR // حسب المبدع
  BY_CAMPAIGN // حسب الحملة (طبقة لاحقة)
}

enum SaleType {
  CONSULTATION
  VIDEO
  STORE_DIGITAL
  STORE_COURSE
  STORE_PHYSICAL
  BOOKING
  CAMPAIGN // إسناد حملة عامّ
  CONTENT // أجر إنتاج محتوى UGC (مكوّن المحتوى)
  USAGE_RIGHTS // أجر حقوق استخدام محتوى
}

enum LedgerStatus {
  ACCRUED // مستحقّة (لم تُسوَّ بعد — السحب لاحقاً)
  SETTLED // سُوِّيت (مع مزوّد حقيقيّ)
  REVERSED // عُكِست (استرداد/إلغاء)
}

// قاعدة عمولة — بأيّ مستوى (عام/نوع/علامة/مبدع/حملة) + فترة زمنيّة اختياريّة.
// النسبة بنقاط الأساس (bps: 1000 = 10%) أو مبلغ ثابت (minor) — لدقّة عدد صحيح.
model CommissionRule {
  id          String          @id @default(cuid())
  scope       CommissionScope @default(GLOBAL)
  targetId    String? // creatorProfileId | brandId | campaignId — حسب scope
  saleType    SaleType? // مطابقة نوع البيع (إلزاميّ لـBY_TYPE، فلتر اختياريّ لغيره)
  percentBps  Int? // نقاط أساس (1000 = 10.00%)
  fixedAmount Int? // مبلغ ثابت minor (بديل عن النسبة)
  priority    Int             @default(0) // كسر التعادل داخل نفس المستوى
  startAt     DateTime? // بداية سريان (null = بلا حدّ)
  endAt       DateTime? // نهاية سريان (null = بلا حدّ)
  isActive    Boolean         @default(true)
  label       String? // وصف إداريّ اختياريّ
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([scope])
  @@index([isActive])
  @@index([saleType])
}

// سجلّ العمولة — مصدر الحقيقة. صفّ لكل طلب مؤكّد (قيد فريد يمنع الازدواج).
model CommissionLedger {
  id               String       @id @default(cuid())
  // orderId اختياريّ الآن (additive): عمولة الحملة (UGC/الحقوق) لا طلب شراء لها.
  orderId          String?      @unique
  campaignPayoutId String?      @unique // مصدر عمولة الحملة (UGC/الحقوق) — idempotency
  creatorProfileId String
  brandId          String? // طبقة لاحقة
  campaignId       String? // طبقة لاحقة
  saleType         SaleType
  grossAmount      Int // إجماليّ البيع/الأجر (minor)
  commissionAmount Int // عمولة المنصّة (minor)
  netCreatorAmount Int // صافي المبدع (minor)
  appliedRuleId    String? // القاعدة المطبّقة (null = fallback صفر)
  currency         String
  status           LedgerStatus @default(ACCRUED)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId])
  @@index([status])
  @@index([saleType])
}

// ── دور العلامة (BRAND) + محرّك الإسناد ───────────────────────────────
// حساب علامة موازٍ لـCreatorProfile. الحملات الكاملة لاحقاً (ن18) — هنا الهيكل.
model BrandProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  brandName    String
  logoUrl      String?
  website      String?
  description  String?
  contactEmail String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum CampaignType {
  SALE
  PERFORMANCE
  UGC
}

model Campaign {
  id          String         @id @default(cuid())
  brandId     String
  title       String
  status      CampaignStatus @default(DRAFT)
  type        CampaignType   @default(SALE)
  // إكمال الحملة (additive) — كلّها اختياريّة لعدم كسر الحملات القائمة.
  description String?
  brief       String? // ما تريده العلامة من المبدع
  coverImage  String?
  budgetAmount Int? // minor — بعملة الحملة
  currency    String?
  startAt     DateTime?
  endAt       DateTime?
  targetUrl   String? // وجهة الإسناد (SALE)
  requirements Json? // متطلّبات/شروط المحتوى
  // إعدادات الدفع حسب النوع (json مرن): SALE {creatorBps|fixedPerSale} ·
  // PERFORMANCE {cpcMinor} · UGC {fixedPerContent}. minor بعملة الحملة.
  payoutConfig Json?
  spentAmount Int            @default(0) // مجموع مستحقات المحتوى/المبيعات (حماية الميزانية O(1))
  // حقوق الاستخدام (UGC C6) — additive · ميزانية منفصلة عن ميزانية المحتوى.
  usageRightsWanted Boolean  @default(false) // = usageRightsEnabled (مكوّن الحقوق)
  usageRightsBudget Int? // minor — سقف مستقلّ لأجور الحقوق
  usageRightsSpent  Int      @default(0) // مجموع أجور الحقوق المقبولة (حماية O(1))
  // ── مكوّنات الحملة القابلة للتركيب (additive) — كلٌّ بميزانيّته (لا تسرّب) ──
  // الحملات القائمة تُرحَّل من type إلى المكوّن المكافئ في الهجرة (backfill · لا فقد).
  contentEnabled     Boolean @default(false)
  contentBudget      Int? // minor — ميزانية إنتاج المحتوى
  contentSpent       Int     @default(0)
  contentPerItem     Int? // أجر المحتوى المقبول (minor)
  contentCount       Int? // عدد المحتوى المطلوب (اختياريّ · شفافية)
  saleEnabled        Boolean @default(false)
  saleBudget         Int? // minor — ميزانية مستحقّات البيع
  saleSpent          Int     @default(0)
  saleCreatorBps     Int? // نسبة المبدع (bps)
  saleFixedPerSale   Int? // مبلغ ثابت لكل بيعة (minor)
  performanceEnabled Boolean @default(false)
  performanceBudget  Int? // minor — ميزانية الأداء
  performanceSpent   Int     @default(0)
  performanceCpc     Int? // سعر النقرة (minor)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  brand          BrandProfile            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  participations CampaignParticipation[]
  payouts        CampaignPayout[]
  submissions    ContentSubmission[]

  @@index([brandId])
  @@index([status])
}

enum ParticipationStatus {
  INVITED
  JOINED
  ACTIVE
  LEFT
}

// قلب الإسناد: كل مبدع×حملة له كود ورابط فريدان + عدّادات أداء مجمّعة.
model CampaignParticipation {
  id               String              @id @default(cuid())
  campaignId       String
  creatorProfileId String
  uniqueCode       String              @unique // كود الشراء (كوبون إسناد)
  uniqueLink       String              @unique // مسار التتبّع (/r/<code>)
  status           ParticipationStatus @default(ACTIVE)
  // أداء مجمّع (O(1) قراءة) — يُغذّي ROI لاحقاً.
  clicks           Int                 @default(0)
  conversions      Int                 @default(0)
  sales            Int                 @default(0)
  salesValue       Int                 @default(0) // minor
  payoutAccrued    Int                 @default(0) // مستحقّ المبدع من الحملة (minor)
  joinedAt         DateTime?
  createdAt        DateTime            @default(now())

  campaign          Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorProfile    CreatorProfile     @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  attributionEvents AttributionEvent[]
  orders            Order[]
  payouts           CampaignPayout[]
  submissions       ContentSubmission[]

  @@unique([campaignId, creatorProfileId])
  @@index([campaignId])
  @@index([creatorProfileId])
}

enum AttributionType {
  CLICK
  CONVERSION
  SALE
}

// سجلّ الإسناد الخام (S2S-ready). لا PII — visitorRef مجهول.
model AttributionEvent {
  id              String          @id @default(cuid())
  participationId String
  type            AttributionType
  orderId         String? // بيع مُسنَد (بلا FK — ربط رخو)
  amount          Int? // minor
  visitorRef      String? // مجهول
  source          String?
  createdAt       DateTime        @default(now())

  participation CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@index([participationId])
  @@index([type])
}

// ── مستحقات المبدع من الحملات (سجلّ — مصدر الحقيقة، نفس فلسفة Ledger) ──
enum PayoutType {
  SALE // نسبة/مبلغ من بيعة مُسنَدة (مكوّن البيع)
  PERFORMANCE // لكل نقرة (CPC — مكوّن الأداء)
  UGC // (legacy) لكل محتوى مقبول — استُبدل بـCONTENT
  CONTENT // أجر إنتاج محتوى مقبول (مكوّن المحتوى)
  USAGE_RIGHTS // أجر حقّ استخدام محتوى مقبول (منفصل عن أجر المحتوى)
}

enum PayoutStatus {
  ACCRUED // مستحقّة
  APPROVED // مقبولة (UGC بعد المراجعة)
  PAID // سُوّيت (S32 لاحقاً)
  REVERSED // عُكِست
}

model CampaignPayout {
  id               String       @id @default(cuid())
  campaignId       String
  participationId  String
  creatorProfileId String
  type             PayoutType
  amount           Int // minor — صافي مستحقّ المبدع بعملة الحملة (بعد عمولة المنصّة لـUGC/الحقوق)
  currency         String
  orderId          String?      @unique // SALE: idempotency (null للأنواع الأخرى)
  // UGC/USAGE_RIGHTS (additive): مصدر التسليم + الأجر الإجماليّ وعمولة المنصّة منه.
  submissionId     String? // التسليم المرتبط (المحتوى/الحقوق) — null لـSALE/PERFORMANCE
  usageRightId     String?      @unique // idempotency لمستحقّ الحقوق (يسمح بعدّة تجديدات/تسليم)
  grossAmount      Int? // أجر العلامة الإجماليّ قبل عمولة المنصّة (F) — null للقديم
  commissionAmount Int          @default(0) // عمولة المنصّة (C) — 0 لـSALE/PERFORMANCE
  status           PayoutStatus @default(ACCRUED)
  note             String?
  createdAt        DateTime     @default(now())

  campaign       Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participation  CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  creatorProfile CreatorProfile        @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  submission     ContentSubmission?    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([participationId])
  @@index([creatorProfileId])
  @@index([submissionId])
  @@index([status])
}

// ── UGC: تسليم المحتوى + مراجعة + حقوق الاستخدام (C6) ──────────────────
enum SubmissionType {
  VIDEO
  IMAGE
}

enum SubmissionStatus {
  SUBMITTED // بانتظار مراجعة العلامة
  APPROVED // مقبول → مستحقّ محتوى للمبدع
  AUTO_APPROVED // قُبل تلقائياً (انقضت مهلة المراجعة) → مستحقّ للمبدع
  REJECTED // مرفوض → لا مستحقّ · المحتوى محجوب لا يُستخدم
  REVISION_REQUESTED // طلب تعديل (مرّة واحدة) → يعيد المبدع التسليم
}

// تسليم المبدع لمحتوى حملة UGC. الملف في تخزين خاصّ (assetKey) لا يُخدَم عاماً؛
// يُبَثّ فقط عبر مسار محميّ (العلامة تراجع · التنزيل الإعلانيّ بعد قبول الحقوق).
model ContentSubmission {
  id               String           @id @default(cuid())
  participationId  String
  campaignId       String
  creatorProfileId String
  type             SubmissionType
  assetKey         String // مفتاح التخزين الخاصّ (private) — لا رابط عام
  thumbnailKey     String? // مصغّر خاصّ اختياريّ
  caption          String?
  status           SubmissionStatus @default(SUBMITTED)
  reviewNote       String?
  revisionCount    Int              @default(0) // ≤ 1: طلب تعديل واحد ثم قرار نهائيّ
  reviewDeadlineAt DateTime? // مهلة المراجعة → قبول تلقائيّ بعدها (يحمي المبدع)
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())

  participation  CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  campaign       Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorProfile CreatorProfile        @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  payouts        CampaignPayout[]
  usageRights    UsageRight[] // سلسلة تجديد (الأحدث = الحاليّ)

  @@index([participationId])
  @@index([campaignId])
  @@index([creatorProfileId])
  @@index([status])
}

enum UsageRightStatus {
  NOT_REQUESTED // لا صفّ (حالة مفاهيميّة)
  REQUESTED // طلبت العلامة الحقوق — بانتظار ردّ المبدع
  ACCEPTED // (legacy) قبِل المبدع — استُبدل بـACTIVE
  ACTIVE // سارية ضمن المدّة
  EXPIRING_SOON // قربت النهاية (نافذة تنبيه التجديد)
  DECLINED // رفض المبدع
  EXPIRED // انتهت المدّة (لا استخدام إعلانيّ بعدها)
}

enum UsageScope {
  ORGANIC // عضويّ
  PAID // إعلان مدفوع
  WHITELISTING // whitelisting / Spark Ads (تسجيل النطاق · التنفيذ الفعليّ لاحقاً)
}

// حقّ استخدام لمحتوى مقبول — أجر منفصل فوق الحدّ الأدنى للمنصّة (يضمن العمولة).
model UsageRight {
  id           String           @id @default(cuid())
  // غير فريد: سلسلة تجديد (حقوق متعدّدة لكل تسليم عبر الزمن).
  submissionId String
  status       UsageRightStatus @default(REQUESTED)
  feeAmount    Int // minor — أجر الحقوق بعملة الحملة (≥ الحدّ الأدنى)
  currency     String
  durationDays Int // مدّة السريان بالأيّام
  channels     Json? // { meta, tiktok, youtube, instagram, ... } قنوات مسموحة
  scope        UsageScope       @default(ORGANIC)
  requestedAt  DateTime         @default(now())
  respondedAt  DateTime? // وقت قبول/رفض المبدع
  startAt      DateTime? // بداية السريان (عند القبول)
  endAt        DateTime? // نهاية السريان (عند القبول)
  renewedFromId String? // الحقّ السابق في سلسلة التجديد (دخل متكرّر · لا تعديل للقديم)
  createdAt    DateTime         @default(now())

  submission ContentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([status])
  @@index([renewedFromId])
}

// إعدادات المنصّة (key/value مرن) — الحدّ الأدنى لأجر الحقوق لكل عملة يُخزَّن هنا.
// قرار: جدول إعدادات عامّ (لا توسيع CommissionRule) — أوضح وأعمّ للنموّ.
model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── نظام المحتوى (CMS) — تحرير موضعيّ لمحتوى داخل تخطيط ثابت ────────────
// overlay: القيَم الافتراضيّة من i18n؛ هنا تُخزَّن التجاوزات فقط (fieldKey→value).
// مسوّدة/منشور: الزائر يرى published؛ الأدمن يحرّر draft ثم ينشر.
model PageContent {
  id        String   @id @default(cuid())
  pageKey   String // "landing" | "about" | "contact" | "legal-privacy" | ...
  locale    String // "ar" | "en" | "tr"
  draft     Json? // تجاوزات قيد التحرير { fieldKey: value }
  published Json? // التجاوزات المنشورة (ما يراه الزائر)
  updatedBy String? // معرّف الأدمن الذي حدّث
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([pageKey, locale])
  @@index([pageKey])
}

// رسائل نموذج «تواصل معنا» (تُخزَّن + تُرسَل بريداً عبر المزوّد المحايد).
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  locale    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
