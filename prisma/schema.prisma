// AktBot — Prisma schema (Neon Postgres, pooled)
// القاعدة: additive فقط — لا حذف أعمدة/جداول/بيانات قائمة.
// Prisma 7: لا يوضع url هنا — سلسلة الاتصال في prisma.config.ts، والاتصال عبر adapter.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── فحص السلامة (Bootstrap) — يبقى كما هو ───────────────────────────
model HealthCheck {
  id        String   @id @default(cuid())
  label     String
  createdAt DateTime @default(now())
}

// ── الأدوار وأنواع البلوكات ──────────────────────────────────────────
enum Role {
  CREATOR
  BRAND
  ADMIN
}

// نظام بلوكات كامل البنية — الأنواع تُفعّل بموجات لاحقة (الآن الـenum فقط).
enum BlockType {
  LINK
  FORM
  GALLERY
  EMBED
  CONSULTATION
  PAID_VIDEO
  STORE
  NEWSLETTER
  QR
  BEFORE_AFTER
  STORY
  SOCIAL
  DISCOUNT
}

// ── المستخدم والمصادقة ───────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(CREATOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatorProfile          CreatorProfile?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mediaAssets             MediaAsset[]
}

// أصل صورة مرفوع — يتتبّع الملكيّة (للحذف الآمن) والمفتاح على التخزين.
model MediaAsset {
  id        String   @id @default(cuid())
  key       String   @unique // اسم الملف العشوائيّ على التخزين (cuid.webp)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// التوكنات مُخزّنة مجزّأة (sha256) لا نصاً صريحاً · صلاحية قصيرة · استخدام مرّة واحدة.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── ملف المبدع + الصفحة + البلوكات ───────────────────────────────────
model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  username    String   @unique // مسار aktbot.link/username لاحقاً — slug مُتحقَّق
  displayName String
  bio         String?
  avatarUrl   String?
  language    String   @default("ar")
  direction   String   @default("rtl")
  isPublished Boolean  @default(false)
  // حقول العرض العامّ (additive) — رأس الصفحة العامّة.
  isVerified    Boolean @default(false)
  followerCount Int     @default(0)
  socialLinks   Json? // { instagram, tiktok, youtube, x, website, ... } — تُنقّى عند الإدخال لاحقاً
  createdAt   DateTime @default(now())

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  page        Page?
  orders       Order[]
  subscribers  NewsletterSubscriber[]
  products     Product[]
  availability Availability?
  bookings     Booking[]
  pageViews    PageViewDaily[]
  blockClicks  BlockClick[]
}

// مشتركو النشرة البريديّة لكل مبدع (جمع فقط الآن؛ إرسال الحملات لاحقاً).
model NewsletterSubscriber {
  id               String   @id @default(cuid())
  creatorProfileId String
  email            String
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, email])
  @@index([creatorProfileId])
}

model Page {
  id               String   @id @default(cuid())
  creatorProfileId String   @unique
  theme            Json?
  background       Json?
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  blocks         Block[]
}

model Block {
  id         String    @id @default(cuid())
  pageId     String
  type       BlockType
  config     Json?
  order      Int       @default(0)
  visibility Boolean   @default(true)
  createdAt  DateTime  @default(now())

  page           Page            @relation(fields: [pageId], references: [id], onDelete: Cascade)
  storyViews     StoryView[]
  couponCounters CouponCounter[]

  @@index([pageId])
}

// عدّاد نسخ كوبونات الخصم — مجمّع (أخفّ من صفّ لكل نسخة) · بيانات أفلييت للمبدع.
model CouponCounter {
  id        String   @id @default(cuid())
  blockId   String
  couponId  String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, couponId])
  @@index([blockId])
}

// تتبّع مشاهدة ستوري VIEW_ONCE لكل زائر مجهول (visitorId = كوكي opaque، بلا هوية).
model StoryView {
  id        String   @id @default(cuid())
  blockId   String
  visitorId String
  createdAt DateTime @default(now())

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, visitorId])
  @@index([blockId])
}

// ── الطلبات/المدفوعات (طبقة دفع محايدة) ──────────────────────────────
enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Order {
  id               String      @id @default(cuid())
  creatorProfileId String
  buyerName        String
  buyerEmail       String
  blockType        BlockType? // طلب بلوك: CONSULTATION | PAID_VIDEO
  blockId          String?
  productId        String? // طلب منتج متجر (بديل عن البلوك)
  amount           Int // أصغر وحدة (minor units) — لتفادي أخطاء العشرية
  currency         String
  status           OrderStatus @default(PENDING)
  provider         String      @default("mock")
  providerRef      String?     @unique // مرجع المزوّد — يضمن idempotency للـwebhook
  metadata         Json?
  // حقول الشحن (المنتج الفيزيائيّ) — additive، تبقى null لغير الفيزيائيّ.
  fulfillmentStatus FulfillmentStatus?
  trackingNumber    String?
  shippingFee       Int? // رسوم الشحن بأصغر وحدة (من القاعدة)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creatorProfile  CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  downloadTokens  DownloadToken[]
  enrollment      CourseEnrollment?
  shippingAddress ShippingAddress?
  booking         Booking?

  @@index([creatorProfileId])
  @@index([status])
}

// ── المتجر الفعليّ (شراء داخليّ) ──────────────────────────────────────
enum ProductType {
  DIGITAL
  COURSE
  PHYSICAL
}

model Product {
  id               String      @id @default(cuid())
  creatorProfileId String
  type             ProductType @default(DIGITAL)
  title            String
  description      String?
  price            Int // minor units
  currency         String
  images           Json? // روابط صور (عبر طبقة الرفع)
  isActive         Boolean     @default(true)
  // الفيزيائيّ (additive): مخزون اختياريّ (null = غير محدود) + رسوم شحن اختياريّة.
  stock            Int?
  shippingFee      Int? // minor units
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creatorProfile CreatorProfile     @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  assets         ProductAsset[]
  orders         Order[]
  modules        CourseModule[] // بنية الكورس (type=COURSE)
  enrollments    CourseEnrollment[]

  @@index([creatorProfileId])
}

// ملف المنتج الرقميّ — تخزين خاصّ (fileKey في UPLOAD_DIR/private، لا يُخدَم عاماً).
model ProductAsset {
  id        String   @id @default(cuid())
  productId String
  fileKey   String // مفتاح الملف الخاصّ
  fileName  String
  size      Int
  createdAt DateTime @default(now())

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadTokens DownloadToken[]

  @@index([productId])
}

// رابط تحميل آمن محدود بعد دفع مؤكّد (توكن مجزّأ · صلاحية · حدّ تحميل).
model DownloadToken {
  id             String   @id @default(cuid())
  orderId        String
  productAssetId String
  tokenHash      String   @unique
  expiresAt      DateTime
  maxDownloads   Int      @default(5)
  downloadCount  Int      @default(0)
  createdAt      DateTime @default(now())

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productAsset ProductAsset @relation(fields: [productAssetId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ── الكورس (type=COURSE): وحدات ← دروس، ووصول المشتري عبر Enrollment ──
enum LessonType {
  VIDEO // فيديو مرفوع (خاصّ) أو تضمين
  TEXT // نصّ الدرس
  FILE // ملف مرفق (خاصّ)
}

model CourseModule {
  id        String   @id @default(cuid())
  productId String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([productId])
}

model CourseLesson {
  id         String     @id @default(cuid())
  moduleId   String
  title      String
  order      Int        @default(0)
  type       LessonType @default(TEXT)
  contentRef String? // نصّ الدرس (TEXT) أو رابط تضمين (VIDEO embed)
  assetKey   String? // ملف/فيديو مرفوع في التخزين الخاصّ (VIDEO upload | FILE)
  assetName  String?
  duration   String?
  createdAt  DateTime   @default(now())

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

// وصول المشتري لمحتوى الكورس بعد الدفع — رابط غير قابل للتخمين (مجزّأ).
model CourseEnrollment {
  id               String   @id @default(cuid())
  orderId          String   @unique
  productId        String
  buyerEmail       String
  tokenHash        String   @unique
  completedLessons Json? // تقدّم أساسيّ: معرّفات الدروس المكتملة
  createdAt        DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ── الشحن (type=PHYSICAL) ─────────────────────────────────────────────
enum FulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model ShippingAddress {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fullName   String
  phone      String
  country    String
  city       String
  line       String
  postalCode String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ── حجز المواعيد (ترقية CONSULTATION) ─────────────────────────────────
// توفّر المبدع: نمط أسبوعيّ مرن (JSON) + منطقة زمنية + مدّة/فاصل/أفق.
// اخترتُ توفّراً واحداً لكل مبدع (creatorProfileId @unique) مع weekly JSON
// (أبسط وأمرن من صفوف؛ الاستثناءات JSON اختياريّة).
model Availability {
  id               String   @id @default(cuid())
  creatorProfileId String   @unique
  timezone         String   @default("UTC") // IANA (مثل Europe/Istanbul)
  slotMinutes      Int      @default(30) // مدّة الجلسة
  bufferMinutes    Int      @default(0) // فاصل بين المواعيد
  horizonDays      Int      @default(30) // أفق الحجز مقدّماً
  weekly           Json? // [{ day:0-6, ranges:[{ start:"09:00", end:"17:00" }] }]
  exceptions       Json? // ["2026-07-20", ...] أيام إجازة (تعطيل)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  PENDING // مدفوع بانتظار الدفع (hold)
  CONFIRMED
  CANCELLED
  COMPLETED
}

// حجز موعد. منع الازدواج الذرّيّ عبر slotKey فريد (يُضبط للمواعيد النشطة فقط،
// ويُفرَّغ null عند الإلغاء/انتهاء الـhold فيتحرّر الموعد). المواعيد مولّدة بمحاذاة
// slotMinutes فالتصادم = نفس startAt بالضبط.
model Booking {
  id                  String        @id @default(cuid())
  creatorProfileId    String
  consultationBlockId String
  buyerName           String
  buyerEmail          String
  startAt             DateTime
  endAt               DateTime
  status              BookingStatus @default(PENDING)
  isPaid              Boolean       @default(false)
  orderId             String?       @unique
  meetingLink         String?
  meetingType         String        @default("online") // online | in_person
  holdExpiresAt       DateTime? // للمدفوع PENDING — يُحرَّر بعدها
  slotKey             String?       @unique // "<creatorProfileId>|<startISO>" للنشط، null للمحرَّر
  createdAt           DateTime      @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([creatorProfileId])
  @@index([consultationBlockId])
  @@index([status])
}

// ── التحليلات (تتبّع مجمّع خفيف — مبنيّ للمقياس) ───────────────────────
// قرار: عدّاد يوميّ مجمّع (صفّ لكل مبدع/يوم) لا صفّ لكل زيارة — يتحمّل ملايين
// الزيارات. الفريد اليوميّ يُدَّوب عبر VisitorDay (صفّ لكل زائر فريد/يوم، أصغر
// بكثير من عدد الزيارات). لا PII — معرّف الزائر مجهول (aktbot_vid).
model PageViewDaily {
  id               String   @id @default(cuid())
  creatorProfileId String
  date             String // YYYY-MM-DD (UTC)
  views            Int      @default(0)
  uniques          Int      @default(0)
  srcDirect        Int      @default(0)
  srcSocial        Int      @default(0)
  srcOther         Int      @default(0)
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, date])
  @@index([creatorProfileId])
  @@index([date])
}

// دِدوب الزائر الفريد يوميّاً (لا يُخزَّن أيّ حدث زيارة فرديّ). idempotent عبر القيد.
model VisitorDay {
  id               String   @id @default(cuid())
  creatorProfileId String
  visitorId        String
  date             String
  createdAt        DateTime @default(now())

  @@unique([creatorProfileId, visitorId, date])
  @@index([creatorProfileId, date])
}

// نقرات البلوك — مجمّع (صفّ لكل بلوك). نفس فلسفة CouponCounter.
model BlockClick {
  id               String   @id @default(cuid())
  blockId          String   @unique
  creatorProfileId String
  count            Int      @default(0)
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId])
}
